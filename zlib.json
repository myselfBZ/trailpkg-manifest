{
    "version": "1.3.1",
    "name": "zlib",
    "url": "https://zlib.net/zlib-1.3.2.tar.gz",
    "build_steps": [
        "./configure --prefix={{TRAIL_STORE}}/{{NAME_AND_VERSION}}",
        "make",
        "make install"
    ],
    "out_dir": "lib",
    "export_bin": {},
    "dependencies": [
        {
            "name": "gcc",
            "version_or_higher": "4.0.0",
            "host":true
        },
        {
            "name": "make",
            "version_or_higher": "3.80.0",
            "host":true
        }
    ]
}
