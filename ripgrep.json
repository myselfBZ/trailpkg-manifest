{
    "version": "14.1.0",
    "name": "ripgrep",
    "url": "https://github.com/BurntSushi/ripgrep/archive/refs/tags/14.1.0.tar.gz",
    "build_steps": [
        "cargo build --release --target-dir {{TRAIL_STORE}}/{{NAME_AND_VERSION}}"
    ],
    "out_dir": "release",
    "export_bin":{
        "bins":["rg"]
    },
    "dependencies": [
        {
            "name": "rustc",
            "version_or_higher": "1.70.0",
            "host":true
        },
        {
            "name": "cargo",
            "version_or_higher": "1.70.0",
            "host":true
        }
    ]
}
