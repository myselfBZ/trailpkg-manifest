{
    "version": "1.3",
    "name": "libunistring",
    "url": "https://ftp.gnu.org/gnu/libunistring/libunistring-1.3.tar.gz",
    "build_steps": [
        "./configure --prefix={{TRAIL_STORE}}/{{NAME_AND_VERSION}} --with-libiconv-prefix={{TRAIL_STORE}}/libiconv-{{DEP_VERSION:libiconv}} --disable-static",
        "make -j{{N_CPUS}}",
        "make install"
    ],
    "out_dir": "lib",
    "export_bin": {},
    "dependencies": [
        {
            "name":"libiconv",
            "version_or_higher":"1.11",
            "host":false
        },
        {
            "name": "gcc",
            "version_or_higher": "4.0.0",
            "host":true
        },
        {
            "name": "make",
            "version_or_higher": "3.80.0",
            "host":true
        }
    ]
}
